# Environment variables template for backend
# Copy this to .env and modify as needed

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True

# Server Configuration
HOST=localhost
PORT=5000

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Application Settings
APP_NAME=C Parser Visualizer
APP_VERSION=2.0.0

# Online Compiler — Judge0 CE (free public API, no key required)
JUDGE0_BASE_URL=https://ce.judge0.com
# Optional: only if using a self-hosted Judge0 instance with auth
JUDGE0_AUTH_TOKEN=
JUDGE0_TIMEOUT_SECONDS=60
JUDGE0_CPU_TIME_LIMIT=5
JUDGE0_MEMORY_LIMIT_KB=128000
